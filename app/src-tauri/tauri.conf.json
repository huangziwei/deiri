{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deiri",
  "version": "0.1.0",
  "identifier": "com.ziweih.deiri",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Deiri",
        "width": 1100,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Visible",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
